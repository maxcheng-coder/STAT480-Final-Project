library(haven)
library(survey)
install.packages("data.table")
library(data.table)
# reading in household data data
acs_df_household <- read_sas("psam_h26.sas7bdat")
names(acs_df_household) <- tolower( names( acs_df_household ) )
# reading in person data
acs_df_person <- read.csv("psam_p26.csv")
mem.maxVSize(22000)
# merging the datasets and removing overlap
acs_df_household[ , 'rt' ] <- NULL
acs_df_person[ , 'rt' ] <- NULL
acs_df <- merge( acs_df_household , acs_df_person )
