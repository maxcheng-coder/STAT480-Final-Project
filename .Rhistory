names(dat);
dim(dat);
#> names(dat);
# [1] "cname"       "cnum"        "county"      "precinct"    "eftype"
# [6] "NVoters"     "NValid"      "Votes"       "Ntfraudmean" "Nfraudmean"
#> dim(dat);
#[1] 22820    10
N <- dim(dat)[1];
N;
#sample size n=50
n <- 50;
# simple random sample without replacement
s <- sample(N,n);
y <- ifelse(dat$eftype[s]>1,1,0);
# mean
phat <- sum(y)/n; #estimator (p-hat aka sample proporiton)
phat;
varphat <- phat*(1-phat)/(n-1)*(N-n)/N; #variance of p-hat
varphat;
SEphat <- sqrt(varphat); #standard error of p-hat
boundphat <- 2*sqrt(varphat); #bound on error of estimation
c(phat,SEphat,boundphat)
#sample size n=500
n <- 500;
# simple random sample without replacement
s <- sample(N,n);
y <- ifelse(dat$eftype[s]>1,1,0);
# mean
phat <- sum(y)/n; #estimator (p-hat aka sample proporiton)
phat;
varphat <- phat*(1-phat)/(n-1)*(N-n)/N; #variance of p-hat
varphat;
SEphat <- sqrt(varphat); #standard error of p-hat
boundphat <- 2*sqrt(varphat); #bound on error of estimation
c(phat,SEphat,boundphat)
#sample size n=1500
n <- 1500;
# simple random sample without replacement
s <- sample(N,n);
y <- ifelse(dat$eftype[s]>1,1,0);
# mean
phat <- sum(y)/n; #estimator (p-hat aka sample proporiton)
phat;
varphat <- phat*(1-phat)/(n-1)*(N-n)/N; #variance of p-hat
varphat;
SEphat <- sqrt(varphat); #standard error of p-hat
boundphat <- 2*sqrt(varphat); #bound on error of estimation
c(phat,SEphat,boundphat)
# sample size for mean B=.003
# n <- Np(1-p) / ((N-1)(B^2/4)+p(1-p))
B <- .003;
p <- .05;  # guesstimate for p
nn <- N*p*(1-p) / ((N-1)*(B^2/4)+p*(1-p));
nn;
nB <- ceiling(nn);
nB
# sample
sB <- sample(N,nB);
yB <- ifelse(dat$eftype[sB]>1,1,0); #drawing a sample
# mean
phatB <- sum(yB)/nB; #compute estimated proportion
phatB;
varphatB <- phatB*(1-phatB)/(nB-1)*(N-nB)/N; #compute  variance
varphatB;
SEphatB <- sqrt(varphatB); #compute standard error
boundphatB <- 2*sqrt(varphatB); #compute bound
c(phatB,SEphatB,boundphatB);
c(phat,SEphat,boundphat);
