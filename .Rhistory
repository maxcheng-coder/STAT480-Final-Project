# programming in the acs survey design for the survey package
acs_design <- svrepdesign(
weight = ~pwgtp ,
repweights = 'pwgtp[0-9]+' ,
scale = 4 / 80 ,
rscales = rep( 1 , 80 ) ,
mse = TRUE ,
type = 'JK1' ,
data = acs_df
)
